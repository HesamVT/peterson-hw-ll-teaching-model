{UTF-8}
avg time between fires=
	3
	~	Year [0.1,10,0.1]
	~	Peterson's appendix refers to this quantity as fire frequency, but in this teaching version it is kept explicitly as the average time between fires.	|

fire frequency=
	1/avg time between fires
	~	1/Year
	~	Defined here as the inverse of average time between fires so that fire frequency keeps its standard dimensional meaning of fires per unit time.	|

"HardWood (HW)"= INTEG (
	HW growth-HW destruction,
		init HW)
	~	Dmnl
	~		|

HW destruction=
	"HW destruction rate (f)"*"HardWood (HW)"*("LongLeaf (LL)")^3
	~	1/Year
	~		|

"HW destruction rate (f)"=
	proportion of HW killed by a fire*fire frequency
	~	1/Year
	~		|

HW growth=
	"HW growth rate (r)"*"HardWood (HW)"*"LongLeaf (LL)"
	~	1/Year
	~		|

"HW growth rate (r)"=
	0.075
	~	1/Year [0,1,0.001]
	~		|

init HW=
	0.329175
	~	Dmnl [0,1,0.001]
	~		|

"LongLeaf (LL)"=
	1-"HardWood (HW)"
	~	Dmnl
	~		|

proportion of HW killed by a fire=
	0.5
	~	Dmnl [0,1,0.01]
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

